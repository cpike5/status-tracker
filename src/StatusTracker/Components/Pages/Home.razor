@page "/"
@rendermode InteractiveServer

@using StatusTracker.Services
@using StatusTracker.Entities

@inject IEndpointService EndpointService
@inject ICheckResultService CheckResultService
@inject IStatusUpdateNotifier Notifier
@inject ILogger<Home> Logger

@implements IAsyncDisposable

<PageTitle>Dashboard — @(SiteTitle ?? "Status Page")</PageTitle>

@if (_loadError is not null)
{
    <div class="dashboard-error" role="alert">
        <p>Failed to load dashboard data. Please refresh the page.</p>
    </div>
}
else if (_allEndpoints is null)
{
    <div class="dashboard-loading" aria-busy="true" aria-label="Loading dashboard">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
    </div>
}
else
{
    <SystemBanner Endpoints="@_allEndpoints" />

    <div class="dashboard-groups">
        @{
            var runningIndex = 0;
        }
        @foreach (var group in _sortedGroups)
        {
            <EndpointGroup GroupName="@group.Key"
                           Endpoints="@group.Endpoints"
                           DailySummariesByEndpoint="@_dailySummaries"
                           BaseIndex="@runningIndex" />
            runningIndex += group.Endpoints.Count;
        }
    </div>
}

@code {
    [CascadingParameter(Name = "SiteTitle")] private string? SiteTitle { get; set; }

    private const int MaxLoadRetries = 3;
    private static readonly TimeSpan RetryDelay = TimeSpan.FromSeconds(2);

    private List<EndpointStatusDto>? _allEndpoints;
    private Dictionary<int, List<DailyUptimeSummary>> _dailySummaries = new();
    private List<(string? Key, List<EndpointStatusDto> Endpoints)> _sortedGroups = [];
    private string? _loadError;
    private readonly CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        Notifier.OnEndpointUpdated += HandleEndpointUpdated;

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        for (var attempt = 1; attempt <= MaxLoadRetries; attempt++)
        {
            try
            {
                var endpoints = await EndpointService.GetWithStatusAsync();

                var summaries = new Dictionary<int, List<DailyUptimeSummary>>();
                foreach (var e in endpoints)
                {
                    summaries[e.Endpoint.Id] = await CheckResultService.GetDailyUptimeSummaryAsync(e.Endpoint.Id, 90);
                }

                _dailySummaries = summaries;

                _sortedGroups = endpoints
                    .GroupBy(e => e.Endpoint.Group)
                    .Select(g => (
                        Key: g.Key,
                        Endpoints: g.OrderBy(e => e.Endpoint.SortOrder).ThenBy(e => e.Endpoint.Name).ToList(),
                        MinSort: g.Min(e => e.Endpoint.SortOrder)
                    ))
                    .OrderBy(g => g.MinSort)
                    .ThenBy(g => g.Key)
                    .Select(g => (g.Key, g.Endpoints))
                    .ToList();

                _allEndpoints = endpoints;
                _loadError = null;
                return;
            }
        catch (Exception ex) when (attempt < MaxLoadRetries)
        {
            Logger.LogWarning(ex, "Dashboard load attempt {Attempt}/{MaxRetries} failed, retrying",
                attempt, MaxLoadRetries);
            await Task.Delay(RetryDelay, _cts.Token);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load dashboard data after {MaxRetries} attempts", MaxLoadRetries);
            _loadError = ex.Message;
        }
        }
    }

    private async Task RefreshEndpointAsync(int endpointId)
    {
        try
        {
            var endpoints = await EndpointService.GetWithStatusAsync();
            var summaries = await CheckResultService.GetDailyUptimeSummaryAsync(endpointId, 90);

            _dailySummaries[endpointId] = summaries;

            _sortedGroups = endpoints
                .GroupBy(e => e.Endpoint.Group)
                .Select(g => (
                    Key: g.Key,
                    Endpoints: g.OrderBy(e => e.Endpoint.SortOrder).ThenBy(e => e.Endpoint.Name).ToList(),
                    MinSort: g.Min(e => e.Endpoint.SortOrder)
                ))
                .OrderBy(g => g.MinSort)
                .ThenBy(g => g.Key)
                .Select(g => (g.Key, g.Endpoints))
                .ToList();

            _allEndpoints = endpoints;
            _loadError = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to refresh data for endpoint {EndpointId}", endpointId);
        }
    }

    private void HandleEndpointUpdated(int endpointId)
    {
        _ = InvokeAsync(async () =>
        {
            if (_cts.IsCancellationRequested) return;
            try
            {
                await RefreshEndpointAsync(endpointId);
                StateHasChanged();
            }
            catch (ObjectDisposedException) { }
            catch (OperationCanceledException) { }
        });
    }

    public async ValueTask DisposeAsync()
    {
        Notifier.OnEndpointUpdated -= HandleEndpointUpdated;
        await _cts.CancelAsync();
        _cts.Dispose();
    }
}
