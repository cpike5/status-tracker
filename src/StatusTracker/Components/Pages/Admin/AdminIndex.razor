@page "/admin"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using StatusTracker.Services
@inject IEndpointService EndpointService
@inject NavigationManager Navigation

<PageTitle>Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 px-0" />

    <div class="mb-6">
        <MudText Typo="Typo.h3">Administration</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-1">
            Manage your status page configuration and monitored endpoints.
        </MudText>
    </div>

    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-6 d-flex flex-column" Elevation="1" Style="height: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.MonitorHeart"
                         Color="Color.Primary"
                         Style="font-size: 2.5rem; margin-bottom: 1rem;" />
                <MudText Typo="Typo.h6">Manage Endpoints</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Add, edit, and monitor your HTTP endpoints.
                </MudText>
                <MudSpacer />
                @if (_endpointCount is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                        @_endpointCount endpoint@(_endpointCount == 1 ? "" : "s") configured
                    </MudText>
                }
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           FullWidth="true"
                           Href="/admin/endpoints"
                           StartIcon="@Icons.Material.Filled.ArrowForward">
                    Go to Endpoints
                </MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="pa-6 d-flex flex-column" Elevation="1" Style="height: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.Tune"
                         Color="Color.Primary"
                         Style="font-size: 2.5rem; margin-bottom: 1rem;" />
                <MudText Typo="Typo.h6">Site Settings</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Configure your site title, logo, accent color, and footer text.
                </MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           FullWidth="true"
                           Href="/admin/settings"
                           StartIcon="@Icons.Material.Filled.ArrowForward">
                    Go to Settings
                </MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private int? _endpointCount;

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", href: "/"),
        new("Admin", href: null, disabled: true),
    ];

    protected override async Task OnInitializedAsync()
    {
        var endpoints = await EndpointService.GetAllAsync();
        _endpointCount = endpoints.Count;
    }
}
