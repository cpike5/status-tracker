@page "/admin/endpoints/create"
@rendermode InteractiveServer
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using StatusTracker.Components.Shared
@using StatusTracker.Entities
@using StatusTracker.Services

@inject IEndpointService EndpointService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject ILogger<EndpointCreate> Logger

<PageTitle>Create Endpoint</PageTitle>

<div class="page-header mb-6">
    <MudBreadcrumbs Items="_breadcrumbs" />
    <MudText Typo="Typo.h4" Class="mt-2">Create Endpoint</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Add a new HTTP endpoint to monitor.
    </MudText>
</div>

<MudPaper Class="pa-6" Elevation="1">
    <EndpointForm Endpoint="_endpoint"
                  OnValidSubmit="HandleCreateAsync"
                  IsEdit="false" />
</MudPaper>

@code {
    private MonitoredEndpoint _endpoint = new()
    {
        CheckIntervalSeconds = 60,
        ExpectedStatusCode = 200,
        TimeoutSeconds = 10,
        RetryCount = 2,
        IsEnabled = true,
        IsPublic = false,
        SortOrder = 0
    };

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Dashboard", href: "/"),
        new("Endpoints", href: "/admin/endpoints"),
        new("Create", href: null, disabled: true)
    ];

    private async Task HandleCreateAsync()
    {
        try
        {
            await EndpointService.CreateAsync(_endpoint);
            Logger.LogInformation("Created endpoint {EndpointName} at {Url}", _endpoint.Name, _endpoint.Url);
            Snackbar.Add($"Endpoint \"{_endpoint.Name}\" created successfully.", Severity.Success);
            Navigation.NavigateTo("/admin/endpoints");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create endpoint {EndpointName}", _endpoint.Name);
            Snackbar.Add("Failed to create endpoint. Please try again.", Severity.Error);
        }
    }
}
