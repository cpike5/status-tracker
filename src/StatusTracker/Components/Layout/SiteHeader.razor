@using Microsoft.AspNetCore.Components.Authorization

<header class="site-header">
    <div class="header-content">
        <div class="d-flex align-center gap-2">
            @if (!string.IsNullOrEmpty(LogoUrl))
            {
                <a href="/">
                    <img src="@LogoUrl" alt="@SiteTitle" style="max-height: 32px;" />
                </a>
            }
            <a href="/" class="site-title">@SiteTitle</a>
        </div>

        <AuthorizeView>
            <Authorized>
                <span class="live-indicator">
                    <span class="live-dot" aria-hidden="true"></span>
                    <span>Live</span>
                </span>

                @* Desktop nav — hidden on mobile *@
                <div class="nav-meta">
                    <span class="separator">|</span>
                    <span class="last-updated">Last updated: @FormatLocalTime(DateTime.UtcNow)</span>
                    <span class="separator">|</span>
                    <MudMenu Icon="@Icons.Material.Filled.Settings"
                             Size="Size.Small"
                             Color="Color.Inherit"
                             AnchorOrigin="Origin.BottomRight"
                             TransformOrigin="Origin.TopRight"
                             Dense="true"
                             aria-label="Admin menu">
                        <MudMenuItem Href="/admin"
                                     Icon="@Icons.Material.Filled.Dashboard">
                            Admin
                        </MudMenuItem>
                        <MudMenuItem Href="/admin/endpoints"
                                     Icon="@Icons.Material.Filled.MonitorHeart">
                            Manage Endpoints
                        </MudMenuItem>
                        <MudMenuItem Href="/admin/settings"
                                     Icon="@Icons.Material.Filled.Tune">
                            Site Settings
                        </MudMenuItem>
                    </MudMenu>
                    <span class="separator">|</span>
                    <MudLink Href="/api/auth/logout" Color="Color.Inherit" Typo="Typo.caption" Style="font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.10em;">Logout</MudLink>
                </div>

                @* Mobile nav — visible on small screens *@
                <div class="mobile-menu">
                    <MudMenu Icon="@Icons.Material.Filled.Menu"
                             Size="Size.Small"
                             Color="Color.Inherit"
                             AnchorOrigin="Origin.BottomRight"
                             TransformOrigin="Origin.TopRight"
                             aria-label="Navigation menu">
                        <MudMenuItem Href="/admin"
                                     Icon="@Icons.Material.Filled.Dashboard">
                            Admin
                        </MudMenuItem>
                        <MudMenuItem Href="/admin/endpoints"
                                     Icon="@Icons.Material.Filled.MonitorHeart">
                            Manage Endpoints
                        </MudMenuItem>
                        <MudMenuItem Href="/admin/settings"
                                     Icon="@Icons.Material.Filled.Tune">
                            Site Settings
                        </MudMenuItem>
                        <MudMenuItem Href="/api/auth/logout"
                                     Icon="@Icons.Material.Filled.Logout">
                            Logout
                        </MudMenuItem>
                    </MudMenu>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</header>

@code {
    [Parameter] public string SiteTitle { get; set; } = "Status Page";
    [Parameter] public string? LogoUrl { get; set; }
    [Parameter] public TimeZoneInfo? BrowserTimeZone { get; set; }

    private string FormatLocalTime(DateTime utcTime)
    {
        if (BrowserTimeZone is not null)
        {
            var local = TimeZoneInfo.ConvertTimeFromUtc(
                DateTime.SpecifyKind(utcTime, DateTimeKind.Utc), BrowserTimeZone);
            return local.ToString("h:mm:ss tt");
        }
        return utcTime.ToString("h:mm:ss tt") + " UTC";
    }
}
