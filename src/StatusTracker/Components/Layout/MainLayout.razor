@inherits LayoutComponentBase
@using StatusTracker.Services
@using StatusTracker.Entities
@inject ISiteSettingsService SettingsService
@inject IJSRuntime JS
@inject ILogger<MainLayout> Logger

<MudThemeProvider Theme="@_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingValue Value="@_siteTitle" Name="SiteTitle">
<CascadingValue Value="@_browserTimeZone" Name="BrowserTimeZone">
<div class="app-layout">
    <SiteHeader SiteTitle="@_siteTitle" LogoUrl="@_logoUrl" BrowserTimeZone="@_browserTimeZone" />

    <main class="main-content page-enter">
        @Body
    </main>

    <SiteFooter FooterText="@_footerText" />
</div>
</CascadingValue>
</CascadingValue>

@code {
    private MudTheme _theme = ThemeFactory.Build();
    private string _siteTitle = "Status Page";
    private string? _logoUrl;
    private string? _footerText;
    private string? _accentColor;
    private TimeZoneInfo? _browserTimeZone;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var settings = await SettingsService.GetAsync();
            _siteTitle = settings.SiteTitle;
            _logoUrl = settings.LogoUrl;
            _footerText = settings.FooterText;
            _accentColor = settings.AccentColor;
            _theme = ThemeFactory.Build(settings.AccentColor);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load site settings; using defaults");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (_accentColor is not null)
        {
            try
            {
                await JS.InvokeVoidAsync("setAccentColor", _accentColor);
            }
            catch
            {
                // Non-critical — CSS custom property won't update
            }
        }

        try
        {
            var tzName = await JS.InvokeAsync<string?>("getBrowserTimezone");
            if (tzName is not null)
            {
                _browserTimeZone = TimeZoneInfo.FindSystemTimeZoneById(tzName);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to resolve browser timezone; falling back to UTC");
        }
    }
}
