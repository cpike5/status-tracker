{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  },
  "HealthCheck": {
    "DefaultIntervalSeconds": 60,
    "DefaultTimeoutSeconds": 10,
    "DefaultRetryCount": 2,
    "MaxConcurrency": 10
  },
  "DataRetention": {
    "RetentionDays": 90,
    "PruneSchedule": "0 2 * * *"
  },
  "AllowedHosts": "*"
}
