# =============================================================================
# Status Tracker — Environment Variables
# =============================================================================

# Required
POSTGRES_PASSWORD=changeme
ALLOWED_EMAILS=admin@example.com
ASPNETCORE_ENVIRONMENT=Production

# Seq (generate hash: echo -n "password" | docker run --rm -i datalust/seq config hash)
SEQ_PASSWORD=

# OAuth — configure at least one provider
# Callback (redirect) URLs to register with each provider:
#   Google:    https://<your-domain>/signin-google
#   Microsoft: https://<your-domain>/signin-microsoft
#   GitHub:    https://<your-domain>/signin-github
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Elastic APM (optional, production)
# ElasticApm__ServerUrl=http://apm-server:8200
# ElasticApm__ServiceName=status-tracker
# ElasticApm__Environment=production
