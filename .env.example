# =============================================================================
# Status Tracker — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before running docker compose.
#
#   cp .env.example .env
#
# Variables marked REQUIRED must be set before the application will start in
# Production mode. Variables marked OPTIONAL have defaults that are applied
# automatically when the value is absent or empty.
# =============================================================================


# =============================================================================
# Database
# =============================================================================

# REQUIRED
# Password for the PostgreSQL database. Used by both the postgres container
# (as the superuser/app user password) and by the application container to
# build its connection string:
#   Host=postgres;Port=5432;Database=statustracker;Username=app;Password=<value>
POSTGRES_PASSWORD=changeme


# =============================================================================
# Application
# =============================================================================

# OPTIONAL — default: Production
# ASP.NET Core runtime environment. Set to "Development" to enable the
# developer exception page and skip the fail-fast startup validation that
# requires OAuth credentials and a database connection string.
ASPNETCORE_ENVIRONMENT=Production

# REQUIRED (in Production)
# Comma-separated list of email addresses that are allowed to log in.
# At least one address must be present when ASPNETCORE_ENVIRONMENT is not
# "Development". Mapped internally to the Auth:AllowedEmails configuration key.
#
# Examples:
#   Single address:   ALLOWED_EMAILS=admin@example.com
#   Multiple:         ALLOWED_EMAILS=alice@example.com,bob@example.com
ALLOWED_EMAILS=admin@example.com


# =============================================================================
# OAuth Providers
# =============================================================================
# At least one provider must be configured (both CLIENT_ID and CLIENT_SECRET)
# when ASPNETCORE_ENVIRONMENT is not "Development". The login page renders
# buttons only for providers whose credentials are present. Providers with
# empty or missing credentials are ignored entirely.
#
# Callback (redirect) URLs — register these with each provider's developer
# console before filling in credentials:
#
#   Google:    https://<your-domain>/signin-google
#   Microsoft: https://<your-domain>/signin-microsoft
#   GitHub:    https://<your-domain>/signin-github
#
# For local development use:
#   https://localhost:<port>/signin-google   (or -microsoft / -github)

# Google — https://console.cloud.google.com/apis/credentials
# Note: docker-compose.yml maps these to Google__ClientId / Google__ClientSecret so that
# ASP.NET Core's __ separator convention translates them to the Google:ClientId config key.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft — https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# GitHub — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


# =============================================================================
# Seq (structured log viewer)
# =============================================================================
# OPTIONAL — If left empty, Seq starts without password protection.
#
# Bcrypt hash of the Seq admin password. Generate with:
#   echo 'YourPassword' | docker run --rm -i datalust/seq:latest seq config --print-input-password-hash
#
# The Seq UI is available at http://localhost:8081 (docker-compose default).
# Seq receives logs at http://seq:5341 (internal network, set automatically).
SEQ_PASSWORD=


# =============================================================================
# Elastic APM (optional — production telemetry)
# =============================================================================
# APM is enabled only when ElasticApm__ServerUrl is non-empty. All three
# variables are passed through docker-compose using the __ separator which
# ASP.NET Core maps to nested configuration keys (ElasticApm:ServerUrl, etc.).
#
# PREREQUISITE: The application container connects to the APM server over the
# external "elastic" Docker network. Create it once before running docker compose:
#
#   docker network create elastic
#
# If you are NOT using Elastic APM, leave ElasticApm__ServerUrl empty (or remove
# it) and also remove the elastic network entries from docker-compose.yml to avoid
# a startup error when the network does not exist.
#
# Uncomment and set these to enable APM:
# ElasticApm__ServerUrl=http://apm-server:8200
# ElasticApm__ServiceName=status-tracker
# ElasticApm__Environment=production
